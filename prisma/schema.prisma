generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  OWNER
  USER
}

model User {
  id             String     @id @default(uuid())
  name           String     @unique
  role           Role
  accessCode     String
  spotifyUserId  String?
  createdAt      DateTime   @default(now())

  playlists      Playlist[]
}

model Song {
  id             String         @id @default(uuid())
  title          String
  artist         String
  album          String?

  spotifyId      String?        @unique

  youtubeId      String?
  youtubeAltIds  String[]

  createdAt      DateTime       @default(now())

  playlistSongs  PlaylistSong[]
}

model Playlist {
  id         String         @id @default(uuid())
  name       String
  userId     String
  user       User           @relation(fields: [userId], references: [id])
  songs      PlaylistSong[]
  createdAt  DateTime       @default(now())

  @@index([userId])
}

model PlaylistSong {
  id          String    @id @default(uuid())
  playlistId  String
  songId      String
  order       Int
  createdAt   DateTime  @default(now())

  playlist    Playlist  @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  song        Song      @relation(fields: [songId], references: [id])

  @@unique([playlistId, songId])
  @@index([playlistId])
  @@index([songId])
}

model SpotifyConnection {
  id             String   @id @default("singleton")
  accessToken    String
  refreshToken   String
  expiresAt      DateTime
  scope          String
  spotifyUserId  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
