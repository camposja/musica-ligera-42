generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// Role and PlaylistSource were Postgres enums. SQLite has no enum support,
// so they're stored as String columns and validated via app-side string-
// literal types (see `src/types/api.ts`). Allowed Role values:
// "OWNER" | "USER". Allowed PlaylistSource values:
// "MANUAL" | "SPOTIFY_IMPORT" | "CLONE".

model User {
  id             String     @id @default(uuid())
  // Names preserve display casing. Login lookup is case-insensitive via a
  // JS-side compare in the login route (SQLite has no case-insensitive
  // equality operator at the Prisma layer; the user table is tiny so a
  // findMany + .find() is cheap).
  name           String     @unique
  role           String
  accessCode     String
  spotifyUserId  String?
  createdAt      DateTime   @default(now())

  playlists      Playlist[]
}

model Song {
  id             String         @id @default(uuid())
  title          String
  artist         String
  album          String?

  spotifyId      String?        @unique

  youtubeId      String?
  // JSON-encoded string[] of alternate YouTube ids. SQLite has no array type
  // so we serialize at write and parse at read via helpers in
  // `src/lib/song-serialization.ts`. API responses still expose
  // `youtubeAltIds: string[]` via `normalizeSong`.
  youtubeAltIdsJson String       @default("[]")

  // Match-quality metadata. Null on legacy matches written before
  // the looser-matching ticket (Ticket 8). New + rematched songs
  // populate these so the UI can label exact vs loose matches.
  youtubeMatchType    String?  // "exact" | "loose"
  youtubeMatchReason  String?  // "exact" | "live" | "lyric_video" | "official_audio" | "acoustic" | "remaster" | "remix" | "close" | "manual"
  youtubeMatchTitle   String?  // YouTube result title at match time
  youtubeMatchChannel String?  // YouTube channel name at match time

  createdAt      DateTime       @default(now())

  playlistSongs  PlaylistSong[]
}

model Playlist {
  id           String         @id @default(uuid())
  name         String
  userId       String
  user         User           @relation(fields: [userId], references: [id])
  songs        PlaylistSong[]
  createdAt    DateTime       @default(now())

  source       String         @default("MANUAL")
  locked       Boolean        @default(false)
  clonedFromId String?
  importedAt   DateTime?
  sourceLabel  String?

  @@index([userId])
  @@index([clonedFromId])
}

model PlaylistSong {
  id          String    @id @default(uuid())
  playlistId  String
  songId      String
  order       Int
  createdAt   DateTime  @default(now())

  playlist    Playlist  @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  song        Song      @relation(fields: [songId], references: [id])

  @@unique([playlistId, songId])
  @@index([playlistId])
  @@index([songId])
}

model SpotifyConnection {
  id             String   @id @default("singleton")
  accessToken    String
  refreshToken   String
  expiresAt      DateTime
  scope          String
  spotifyUserId  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
