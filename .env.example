DATABASE_URL=postgresql://postgres:postgres@localhost:5433/music_app

OWNER_USERNAME=
OWNER_PASSWORD=
SESSION_SECRET=

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# NOTE: Spotify rejects http://localhost (policy 2024). Use 127.0.0.1 in .env,
# the Spotify Dashboard redirect URI, AND the URL you visit in your browser
# (http://127.0.0.1:3000). Mismatches break the OAuth state cookie.
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/api/spotify/callback

YOUTUBE_API_KEY=
