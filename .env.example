# SQLite. The file is created automatically on first `pnpm prisma migrate dev`.
DATABASE_URL=file:./dev.db

OWNER_USERNAME=
OWNER_PASSWORD=
SESSION_SECRET=

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# NOTE: Spotify rejects http://localhost (policy 2024). Use 127.0.0.1 in .env,
# the Spotify Dashboard redirect URI, AND the URL you visit in your browser
# (http://127.0.0.1:3000). Mismatches break the OAuth state cookie.
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/api/spotify/callback

YOUTUBE_API_KEY=

# Optional playback fallback. Leave unset to use only yt-dlp.
# Point at any currently-working Piped instance (the public list rotates) or
# a self-hosted one. Changing this requires restarting `pnpm dev` — providers
# are memoized on first call.
PIPED_API_BASE_URL=
